# =============================================================================
# Homelab Dashboard — Environment Configuration
# Copy this file to .env and fill in your values. The deploy.sh script will
# generate .env automatically on first run by asking only for the handful of
# values that must be known before containers start.
#
# Everything NOT in the "Compose-time" section below is optional and is best
# configured from the in-app Settings page after first login — those values
# are persisted to config.yml. Leaving them blank here is fine.
# =============================================================================

# -----------------------------------------------------------------------------
# Compose-time (asked by setup-wizard.sh on first run)
# -----------------------------------------------------------------------------

# Set to true to run with mock data (no real integrations required)
BACKEND_MOCK=false

# External hostname or IP used to access this server from your browser.
# For raw IP mode this is your server's LAN IP (e.g. 192.168.1.50).
# For domain mode this is your local domain (e.g. homelab.local).
EXTERNAL_HOST=192.168.1.50

# How this instance is accessed: "ip" or "domain"
DOMAIN_MODE=ip

# Certificate strategy: "none" (HTTP only), "selfsigned", or "letsencrypt"
# letsencrypt requires a public domain + ports 80/443 forwarded to this server.
CERT_TYPE=none

# Let's Encrypt contact email (only used when CERT_TYPE=letsencrypt)
LETSENCRYPT_EMAIL=

# -----------------------------------------------------------------------------
# Port Assignments
# These are auto-assigned by deploy.sh to avoid conflicts with existing
# Docker containers. Change them here if you need to override manually.
# -----------------------------------------------------------------------------

# Main dashboard UI port
FRONTEND_PORT=8080

# Backend API port (internal — you typically won't need to access this directly)
BACKEND_PORT=8000

# NGINX Proxy Manager ports (only used when CERT_TYPE != none)
# Defaults pick high ports to avoid conflicts with existing web servers
NPM_HTTP_PORT=8080
NPM_HTTPS_PORT=8443
NPM_ADMIN_PORT=8181

# OpenVAS vulnerability scanner web UI port
OPENVAS_HTTP_PORT=9392

# OpenVAS GMP protocol port (internal backend use only)
OPENVAS_PORT=9390

# -----------------------------------------------------------------------------
# Runtime integrations — OPTIONAL overrides
#
# You normally DO NOT need to set any of the values below. They are collected
# from the in-app Settings page on first login and stored in config.yml.
# Values set here will override config.yml at container start, which is useful
# for CI / automated redeploys.
# -----------------------------------------------------------------------------

# UniFi (UDM Pro)
UNIFI_URL=
UNIFI_USER=
UNIFI_PASS=
UNIFI_SITE=default

# Elasticsearch
ES_HOST=
ES_PORT=9200
ES_USER=
ES_PASS=

# OpenVAS / Greenbone management API
OPENVAS_USER=admin
OPENVAS_PASS=

# Claude Code integration (unknown-device auto-identification)
CLAUDE_ENABLED=false
CLAUDE_API_KEY=

# -----------------------------------------------------------------------------
# Scan Intervals (overridable via the Settings UI at runtime)
# -----------------------------------------------------------------------------

# Comma-separated Nmap scan targets (CIDRs or hostnames).
# Leave blank to auto-derive a /24 from EXTERNAL_HOST.
# Examples: "192.168.1.0/24"  or  "192.168.1.0/24,10.0.0.0/24"
NMAP_TARGETS=

# How often to run Nmap network scans (minutes)
NMAP_INTERVAL_MINUTES=15

# How often to poll the UniFi controller (seconds)
UNIFI_POLL_INTERVAL_SECONDS=30

# How often to run OpenVAS vulnerability scans (hours)
OPENVAS_INTERVAL_HOURS=24

# -----------------------------------------------------------------------------
# Container runtime — rarely touched but important to know about
# -----------------------------------------------------------------------------

# Host's docker group GID — lets the non-root backend user talk to the
# docker socket for the OpenVAS reset/rotate flow.
#
# If you deploy via `./deploy.sh`, this value is auto-detected from the
# remote host (`stat -c '%g' /var/run/docker.sock`) and updated on every
# run — no manual action needed, even if you move to a different distro.
#
# If you deploy manually, set it yourself:
#   stat -c '%g' /var/run/docker.sock    # on the server
# Typical values: 999 (Debian/Ubuntu), 988 (RHEL/Fedora), 1001 (some clouds),
# 0 (rootless / Docker Desktop — `group_add: ["0"]` works but is ugly).
DOCKER_GID=999

# Bind prefix for the backend host-port. Leave blank to bind on all
# interfaces (backwards compatible, easy LAN access). Set to "127.0.0.1:"
# for production so the backend is only reachable via the frontend proxy
# on the same docker network.
BACKEND_BIND=

# Bounded concurrency for Claude analysis runs. Each run costs ~2-4k tokens
# and spawns a sandbox git clone; raising this needs both API headroom and
# good isolation. 2 is "one running, one queued".
CLAUDE_MAX_CONCURRENT=2

# -----------------------------------------------------------------------------
# Opt-in auth — leave blank to keep API open (current default)
# -----------------------------------------------------------------------------

# When set, /api/* requires `Authorization: Bearer <DASHBOARD_TOKEN>`.
# Pair with BACKEND_BIND=127.0.0.1: and a reverse proxy that terminates
# TLS and forwards the Authorization header. The token is a single shared
# secret — not per-user auth. Store the same value in the browser's
# localStorage under the key `dashboard_token`.
DASHBOARD_TOKEN=

# Comma-separated CORS origins for the API. Leave blank to keep the
# permissive `*` default; when DASHBOARD_TOKEN is set, restrict this to
# the hostnames your users actually load the dashboard from.
DASHBOARD_ALLOWED_ORIGINS=
